{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TelegramBot": {
    "AuthToken": ""
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost:5432;Port=5432;Database=tasks;Username=postgres;Password=postgres"
  },
  "SpeechProcessingConfig": {
    "APIURI": ""
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "TaskManager",
    "Audience": "TaskManagerUsers",
    "ExpiryMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithCorrelationId" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "NodeUris": "http://elasticsearch:9200",
          "AutoRegisterTemplate": true,
          "IndexFormat": "taskmanager-logs-{0:yyyy.MM.dd}"
        }
      }
    ]
  },
  "YandexOAuth": {
    "ClientId": "xxx",
    "ClientSecret": "xxx",
    "TokenUrl": "https://oauth.yandex.ru/token",
    "RedirectUri": "",
    "AuthorizeUri": "https://oauth.yandex.ru/authorize"
  },
  "SwaggerPrefix": "",
  "Smtp": {
    "Host": "smtp.yandex.ru",
    "Port": 465,
    "Username": "",
    "Password": "",
    "From": "",
    "UseSsl": true
  },
  "Frontend": {
    "Url": "http://localhost:5173"
  }
}
